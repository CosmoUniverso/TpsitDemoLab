# ── GitHub OAuth App ─────────────────────────────────────────────────────────
# https://github.com/settings/developers → New OAuth App
# Homepage URL:           https://tuo-progetto.vercel.app
# Authorization callback: https://tuo-progetto.vercel.app/api/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=stringa_random_lunga_almeno_32_caratteri

# ── Supabase (usate solo nelle API serverless) ────────────────────────────────
# https://supabase.com → tuo progetto → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...      # service_role key (NON la anon key!)

# ── App URL ───────────────────────────────────────────────────────────────────
# Sviluppo: http://localhost:5173
# Produzione: https://tuo-progetto.vercel.app
APP_URL=http://localhost:5173

# ── Frontend Vite (prefisso VITE_ obbligatorio) ───────────────────────────────
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...    # anon/public key
VITE_APP_URL=http://localhost:5173
